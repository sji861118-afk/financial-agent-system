# ─── DART API (Required) ───────────────────────────────────────
DART_API_KEY=your_dart_api_key_here

# ─── NICE BizAPI (Optional) ────────────────────────────────────
# NICE BizLine 유료 계정에서 발급 (https://openapi.nicebizline.com)
# 기업신용등급 실시간 조회에 사용됩니다.
# NICE_CLIENT_ID=your_client_id
# NICE_CLIENT_SECRET=your_client_secret

# ─── OpenAI API (Optional) ────────────────────────────────────
# AI 재무분석 전문가 소견 생성에 사용됩니다.
# OPENAI_API_KEY=sk-xxx

# ─── Google Gemini API (Optional) ────────────────────────────
# Gemini 2.5 Pro 재무분석 소견 생성 (GPT-4o와 병행 비교)
# Google AI Studio에서 무료 발급: https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIzaSy...

# ─── Firebase (Optional) ──────────────────────────────────────
# If not set, the app falls back to a local JSON file store.
# You can add these later once you have a Firebase project.

# Server-side: paste the full service account JSON as a single line
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Client-side: used by the browser SDK
# NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
