# Vercel production 환경변수 허용목록
# env-audit.sh가 이 파일과 실제 `vercel env ls production`을 diff하여
# 누락/미승인 변수를 감지.
# 포맷: 변수명만 한 줄에 하나. # 주석 허용.

# === 필수 ===
DART_API_KEY
FIREBASE_SERVICE_ACCOUNT_KEY
JWT_SECRET
NEXT_PUBLIC_REVIEW_API_URL

# === Firebase (서버 Admin SDK에서만 참조) ===
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET

# === 외부 API (선택) ===
NICE_CLIENT_ID
NICE_CLIENT_SECRET
FISIS_AUTH_KEY
