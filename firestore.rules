rules_version = '2';

// 보안 정책 (2026-04-21 게시)
// - 모든 Firestore 접근은 서버사이드 Admin SDK(firebase-admin.ts) 경유
// - 클라이언트 Firebase SDK는 사용하지 않음 (firebase.ts는 2026-04-21 삭제, commit e8aa9a4)
// - Admin SDK는 서비스 계정 IAM으로 인증되어 이 규칙을 우회하므로
//   클라이언트 완전 차단은 서버 API 동작에 영향 없음.
// - 배포: app/scripts/firebase-rules.sh (firebase deploy --only firestore:rules)
// - Firebase Console에서 임의로 편집하지 말 것 — 이 파일이 source of truth.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
